# ─────────────────────────────────────────
# PakWheels Clone — Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────

# ── App ──────────────────────────────────
NODE_ENV=development
APP_PORT=4000
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# ── Database (PostgreSQL) ─────────────────
DATABASE_URL=postgresql://pw_user:pw_password@localhost:5432/pw_clone_db

# ── Redis ─────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT Auth ──────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_refresh_secret_too
JWT_REFRESH_EXPIRES_IN=7d

# ── Cloudinary (Media Upload) ─────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email (SMTP) ──────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM="PakWheels Clone <noreply@pw-clone.com>"

# ── Elasticsearch (Phase 5) ───────────────
ELASTICSEARCH_URL=http://localhost:9200

# ── Frontend (Next.js) ────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
